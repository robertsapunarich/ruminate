{
  "name": "@ruminate/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply ruminate --local",
    "db:migrate:remote": "wrangler d1 migrations apply prod-d1-ruminate --remote"
  },
  "dependencies": {
    "@ruminate/shared": "workspace:*",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
